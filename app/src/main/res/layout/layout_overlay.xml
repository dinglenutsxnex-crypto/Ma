<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bg"
    android:clipToOutline="true"
    android:elevation="12dp">

    <LinearLayout
        android:id="@+id/overlay_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header (drag handle) -->
        <LinearLayout
            android:id="@+id/overlay_header"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/overlay_header_bg"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ "
                    android:textColor="#FF8B949E"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAMMERSCALE"
                    android:textColor="#FF00E5FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ]"
                    android:textColor="#FF8B949E"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_live_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#FF8B949E"
                android:textSize="10sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="52dp"
                android:text="···"
                android:textColor="#FF8B949E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_minimize"
                android:layout_width="40dp"
                android:layout_height="52dp"
                android:text="−"
                android:textColor="#FF8B949E"
                android:textSize="20sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Detection strip -->
        <LinearLayout
            android:id="@+id/panel_detection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="#FF0D1117">

            <TextView
                android:id="@+id/tv_server_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WAITING FOR GAME..."
                android:textColor="#FF8B949E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_server_addr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFD29922"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/row_bytes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_bytes_tx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 0 B"
                    android:textColor="#FF3FB950"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#FF444C56"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_bytes_rx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 0 B"
                    android:textColor="#FF58A6FF"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#FF444C56"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_pkt_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pkts"
                    android:textColor="#FF8B949E"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF21262D" />

        <!-- ── TAB BAR ── -->
        <LinearLayout
            android:id="@+id/tab_bar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="#FF0D1117">

            <TextView
                android:id="@+id/tab_flow"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="FLOW"
                android:textColor="#FF00E5FF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="#FF161B22" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#FF21262D" />

            <TextView
                android:id="@+id/tab_tick"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="TICK"
                android:textColor="#FF6E7681"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="#FF0D1117" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#FF21262D" />

            <TextView
                android:id="@+id/tab_stats"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="STATS"
                android:textColor="#FF6E7681"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="#FF0D1117" />

        </LinearLayout>

        <!-- ── TAB CONTENT AREA ── -->
        <FrameLayout
            android:id="@+id/tab_content"
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- ── FLOW TAB (default visible) ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_connections"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:visibility="visible" />

            <!-- ── TICK TAB (decoded 0x01 packet state) ── -->
            <LinearLayout
                android:id="@+id/panel_tick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#FF0D1117"
                android:padding="14dp"
                android:visibility="gone">

                <!-- Seq / tick counter -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="SEQ"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_seq"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FFE6EDF3"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- Load bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="LOAD"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_load_val"
                        android:layout_width="48dp"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFE6EDF3"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <FrameLayout
                        android:id="@+id/tick_load_container"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:background="#FF21262D">

                        <View
                            android:id="@+id/tick_load_bar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="start"
                            android:background="#FF444C56" />

                    </FrameLayout>

                </LinearLayout>

                <!-- Activity label -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="STATE"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_state_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FF8B949E"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FF21262D"
                    android:layout_marginBottom="10dp" />

                <!-- est. X -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="est. X"
                        android:textColor="#FF444C56"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_est_x"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- est. Z -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="est. Z"
                        android:textColor="#FF444C56"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_est_z"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- est. YAW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="est. YAW"
                        android:textColor="#FF444C56"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_est_yaw"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- est. PITCH -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="est. PITCH"
                        android:textColor="#FF444C56"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_est_pitch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FF6E7681"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <!-- Raw size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:text="RAW"
                        android:textColor="#FF444C56"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tick_raw"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#FF444C56"
                        android:textSize="10sp"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="est. fields = bytes[5+] as float32 LE — not confirmed"
                    android:textColor="#FF30363D"
                    android:textSize="8sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- ── STATS TAB ── -->
            <LinearLayout
                android:id="@+id/panel_stats"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#FF0D1117"
                android:padding="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="SESSION" android:textColor="#FF6E7681" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_session"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="—" android:textColor="#FFE6EDF3" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="TICK RATE" android:textColor="#FF6E7681" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_tickrate"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="—" android:textColor="#FFE6EDF3" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#FF21262D" android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="ACTION TICKS" android:textColor="#FF3FB950" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_action"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="0" android:textColor="#FF3FB950" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="IDLE TICKS" android:textColor="#FF6E7681" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_idle"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="0" android:textColor="#FF6E7681" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="WORLD STATES" android:textColor="#FF8957E5" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_world"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="0" android:textColor="#FF8957E5" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="PINGS" android:textColor="#FF444C56" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_pings"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="0" android:textColor="#FF8B949E" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="CLOCK SYNCS" android:textColor="#FF444C56" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_clocks"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="0" android:textColor="#FF58A6FF" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#FF21262D" android:layout_marginBottom="8dp" android:layout_marginTop="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="TX" android:textColor="#FF3FB950" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_tx"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="—" android:textColor="#FF3FB950" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content"
                        android:text="RX" android:textColor="#FF58A6FF" android:textSize="10sp" android:fontFamily="monospace" />
                    <TextView android:id="@+id/stat_rx"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="—" android:textColor="#FF58A6FF" android:textSize="10sp" android:fontFamily="monospace" />
                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Status bar -->
        <TextView
            android:id="@+id/tv_status_bar"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:text="no data yet"
            android:textColor="#FF444C56"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:background="#FF0D1117" />

    </LinearLayout>

    <!-- Dropdown menu panel -->
    <LinearLayout
        android:id="@+id/panel_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="#FF21262D"
        android:elevation="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   DETECTION"
            android:textColor="#FF8B949E"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/menu_detection_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Game Server:  —"
            android:textColor="#FFE6EDF3"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/menu_detection_proto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Protocol:  —"
            android:textColor="#FFE6EDF3"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/menu_detection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Status:  WAITING"
            android:textColor="#FF8B949E"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/menu_detection_bytes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Traffic:  —"
            android:textColor="#FFE6EDF3"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="10dp"
            android:paddingStart="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF30363D" />

        <TextView
            android:id="@+id/menu_clear"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="   CLEAR"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:clickable="true"
