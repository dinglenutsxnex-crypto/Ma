<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:background="@drawable/overlay_bg"
    android:clipToOutline="true"
    android:elevation="12dp">

    <LinearLayout
        android:id="@+id/overlay_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header (drag handle) -->
        <LinearLayout
            android:id="@+id/overlay_header"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/overlay_header_bg"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[ "
                    android:textColor="#FF8B949E"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HAMMERSCALE"
                    android:textColor="#FF00E5FF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ]"
                    android:textColor="#FF8B949E"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Live dot indicator -->
            <TextView
                android:id="@+id/tv_live_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#FF8B949E"
                android:textSize="10sp"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="52dp"
                android:text="···"
                android:textColor="#FF8B949E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_minimize"
                android:layout_width="40dp"
                android:layout_height="52dp"
                android:text="−"
                android:textColor="#FF8B949E"
                android:textSize="20sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Detection panel -->
        <LinearLayout
            android:id="@+id/panel_detection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="#FF0D1117">

            <!-- Game server status -->
            <TextView
                android:id="@+id/tv_server_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WAITING FOR GAME..."
                android:textColor="#FF8B949E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- IP:Port -->
            <TextView
                android:id="@+id/tv_server_addr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFD29922"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <!-- Bytes / packets row -->
            <LinearLayout
                android:id="@+id/row_bytes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_bytes_tx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑ 0 B"
                    android:textColor="#FF3FB950"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#FF444C56"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_bytes_rx"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 0 B"
                    android:textColor="#FF58A6FF"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  ·  "
                    android:textColor="#FF444C56"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_pkt_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pkts"
                    android:textColor="#FF8B949E"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF21262D" />

        <!-- Connections list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_connections"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scrollbars="none"
            android:overScrollMode="never" />

        <!-- Status bar -->
        <TextView
            android:id="@+id/tv_status_bar"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:text="no data yet"
            android:textColor="#FF444C56"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:background="#FF0D1117" />

    </LinearLayout>

    <!-- Dropdown menu panel -->
    <LinearLayout
        android:id="@+id/panel_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:background="#FF21262D"
        android:elevation="20dp"
        android:visibility="gone">

        <!-- Detection info section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   DETECTION"
            android:textColor="#FF8B949E"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:letterSpacing="0.15" />

        <TextView
            android:id="@+id/menu_detection_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Game Server:  —"
            android:textColor="#FFE6EDF3"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/menu_detection_proto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Protocol:  —"
            android:textColor="#FFE6EDF3"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/menu_detection_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Status:  WAITING"
            android:textColor="#FF8B949E"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="16dp" />

        <TextView
            android:id="@+id/menu_detection_bytes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   Traffic:  —"
            android:textColor="#FFE6EDF3"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"
            android:paddingBottom="10dp"
            android:paddingStart="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF30363D" />

        <TextView
            android:id="@+id/menu_clear"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="   CLEAR"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF30363D" />

        <TextView
            android:id="@+id/menu_download"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="   DOWNLOAD LOGS"
            android:textColor="#FFE6EDF3"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#FF30363D" />

    </LinearLayout>

</FrameLayout>
